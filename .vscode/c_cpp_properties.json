{
    "version": 4,
    "configurations": [
        {
            "name": "Linux CUDA 13.3",
            "compilerPath": "/usr/bin/g++",
            "intelliSenseMode": "linux-gcc-x64",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "defines": [
                "__CUDACC__",
                "__NVCC__",
                "__device__=",
                "__host__=",
                "__global__=",
                "__shared__=",
                "__constant__="
            ],
            "includePath": [
                "${workspaceFolder}/src",
                "${workspaceFolder}/src/cuda-headers",
                "${workspaceFolder}/tools",
                "/usr/local/cuda-13.3/targets/x86_64-linux/include"
            ]
        }
    ]
}